# Supabase (from Dashboard → Project Settings → API)
# Project URL = "Project URL" on the same page as API keys
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
# anon key = "anon public" key (safe for browser; use with RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-anon-key-here

# Optional: server-side only (never use in browser). For API routes / server actions that bypass RLS.
# SUPABASE_SERVICE_ROLE_KEY=
